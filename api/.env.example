# Copy to .env and fill in locally. Never commit .env.
# V0 does not read these yet; reserved for generation and delivery epics.

# Image generation (api/ only — never in kiosk)
# IMAGE_GEN_API_KEY=

# Cloudflare R2 (S3-compatible guest delivery)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
