# Copy to .env and fill in locally. Never commit .env.

# Operator auth (V1 — api/ only; never in kiosk)
OPERATOR_PIN=
JWT_SECRET=

# SQLite (V1 — Prisma)
# DATABASE_URL=file:./data/cabine.db

# Optional: bind address override (default 127.0.0.1; prod/remote in V7)
# API_HOST=127.0.0.1

# Image generation (api/ only — never in kiosk)
# IMAGE_GEN_API_KEY=

# Cloudflare R2 (S3-compatible guest delivery)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
