datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Event {
  id        String    @id @default(cuid())
  name      String    @default("Default Event")
  createdAt DateTime  @default(now())
  sessions  Session[]
  activeBoothConfig BoothConfig?
}

model BoothConfig {
  id                      String @id @default("booth")
  activeEventId           String @unique
  activeEvent             Event  @relation(fields: [activeEventId], references: [id], onDelete: Restrict)
  activeThemeId           String @default("stub-a")
  captureCountdownSeconds Int    @default(3)
  expectedFaceCount       Int    @default(1)
}

model Session {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sceneId   String?
  phase     String
  createdAt DateTime @default(now())
}
